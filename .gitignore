# Dependency directories (المجلدات الناتجة عن تثبيت المكتبات)
node_modules/
jspm_packages/

# Build outputs (المجلدات الناتجة عن تحويل الكود لـ JavaScript)
dist/
build/
out/

# Environment variables (ملفات السرية وكلمات المرور - مهم جداً!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs (ملفات سجلات الأخطاء)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS Metadata (ملفات النظام التشغيل الزائدة)
.DS_Store
Thumbs.db

# IDE Settings (إعدادات برامج البرمجة الخاصة بكِ)
.vscode/
.idea/
*.swp
*.swo

# Docker (ملفات اختيارية تخص دكر)
.docker/